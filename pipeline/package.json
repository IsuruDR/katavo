{
  "name": "podcast-pipeline",
  "version": "0.1.0",
  "private": true,
  "description": "LangGraph.js pipeline for AI podcast generation",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run --exclude tests/integration/**",
    "test:watch": "vitest --exclude tests/integration/**",
    "test:integration": "vitest run tests/integration",
    "reset-user": "tsx scripts/reset-user.ts",
    "make-pro": "tsx scripts/make-pro-user.ts",
    "build-voice-samples": "tsx scripts/build-voice-samples.ts",
    "test-voices": "tsx scripts/test-voices.ts"
  },
  "dependencies": {
    "@expo-google-fonts/ibm-plex-sans": "^0.4.1",
    "@expo-google-fonts/ibm-plex-serif": "^0.4.1",
    "@hono/node-server": "^1.19.13",
    "@langchain/core": "^1.1.44",
    "@langchain/langgraph": "^1.3.0",
    "@langchain/openai": "^1.4.5",
    "@langfuse/langchain": "^5.1.0",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/supabase-js": "^2.0.0",
    "@tavily/core": "^0.7.3",
    "deepagents": "^1.10.0",
    "dotenv": "^16.4.0",
    "hono": "^4.12.12",
    "langfuse": "^3.38.20",
    "openai": "^6.33.0",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "overrides": {
    "@langchain/core": "^1.1.44"
  }
}
