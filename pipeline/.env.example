# Server
PORT=3000

# OpenAI
OPENAI_API_KEY=your-openai-key

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth secrets
PIPELINE_CALLBACK_SECRET=your-pipeline-callback-secret
REVENUCAT_WEBHOOK_SECRET=your-revenucat-webhook-secret

# Push notifications
EXPO_ACCESS_TOKEN=your-expo-access-token

# ElevenLabs (for end-deep-dive duration fetch)
ELEVENLABS_API_KEY=your-elevenlabs-key

# Langfuse
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://your-langfuse-instance.up.railway.app

# Job manager
MAX_CONCURRENT_JOBS=10

# Research agent (v11+)
OPENROUTER_API_KEY=
TAVILY_API_KEY=
RESEARCH_REASONING_MODEL=anthropic/claude-sonnet-4.6
RESEARCH_SUBAGENT_MODEL=anthropic/claude-haiku-4.5
